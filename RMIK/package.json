{
    "name": "rmik-medical-record",
    "version": "1.0.19",
    "description": "RMIK Medical Record",
    "author": "GYA Tech Indonesia",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "start": "cross-env RUNTIME_CONFIG_SOURCE=dotenv node src/index.js",
        "dev": "cross-env RUNTIME_CONFIG_SOURCE=dotenv nodemon --watch src --watch config.json --ext js,json --exec \"node src/index.js\"",
        "agent": "cross-env WORKER_MODE=1 RUNTIME_CONFIG_SOURCE=dotenv node src/index.js",
        "agent:dev": "cross-env WORKER_MODE=1 RUNTIME_CONFIG_SOURCE=dotenv nodemon --watch src --watch config.json --ext js,json --exec \"node src/index.js\"",
        "preview:pemeriksaan_mandiri": "node scripts/preview_pemeriksaan_mandiri_json.js",
        "preview:umur": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8l_gt60",
        "get:6l_lt45_lt40": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=6l_lt45_lt40 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:6l_lt45_gt40": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=6l_lt45_gt40 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:8l_45_59": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8l_45_59 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:8l_gt60": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8l_gt60 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:7p_18_29": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=7p_18_29 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:8p_30_39": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8p_30_39 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:7p_40_44": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=7p_40_44 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:9p_45_59": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=9p_45_59 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:9p_gt60": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=9p_gt60 --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:8l_gt60:l": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8l_gt60 --jenis_kelamin=Laki-laki --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:8l_gt60:p": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8l_gt60 --jenis_kelamin=Perempuan --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:8l_gt60:laki": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8l_gt60 --jenis_kelamin=Laki-laki --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:8l_gt60:perempuan": "node scripts/preview_pemeriksaan_mandiri_json.js --package_key=8l_gt60 --jenis_kelamin=Perempuan --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:paket": "node scripts/preview_pemeriksaan_mandiri_json.js --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:paket:l": "node scripts/preview_pemeriksaan_mandiri_json.js --jenis_kelamin=Laki-laki --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "get:paket:p": "node scripts/preview_pemeriksaan_mandiri_json.js --jenis_kelamin=Perempuan --output=./artifacts/debug/pemeriksaan_mandiri_preview_latest.json",
        "test": "node src/test.js",
        "exe": "electron .",
        "preexe": "node scripts/sanitize-config.js",
        "prebuild": "node scripts/sanitize-config.js",
        "bump:version": "node scripts/bump-version.js",
        "build": "cross-env BUNDLE_PLAYWRIGHT_BROWSER=0 node scripts/download-browser.js && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/build-production.js",
        "build:bundled": "cross-env BUNDLE_PLAYWRIGHT_BROWSER=1 node scripts/download-browser.js && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/build-production.js",
        "publish": "node scripts/publish-updates.js",
        "deploy": "node scripts/deploy-release.js",
        "deploy:bundled": "node scripts/deploy-release.js bundled",
        "deploy:license": "node scripts/deploy-license.js",
        "clean-local": "node scripts/clean-updates-local.js",
        "clean-server": "node scripts/clean-updates-server.js",
        "clean-all": "npm run clean-local && npm run clean-server",
        "clean": "rm -rf storage/*.json"
    },
    "dependencies": {
        "ejs-electron": "^3.0.0",
        "electron-updater": "^6.8.3",
        "node-fetch": "^3.3.2",
        "playwright": "^1.58.0"
    },
    "devDependencies": {
        "basic-ftp": "^5.2.0",
        "cross-env": "^7.0.3",
        "electron": "^40.6.0",
        "electron-builder": "^26.8.1",
        "nodemon": "^3.1.9"
    },
    "build": {
        "appId": "id.go.kemkes.rmik-medical-record",
        "productName": "RMIK",
        "asar": true,
        "asarUnpack": [
            "node_modules/**",
            "src/**"
        ],
        "publish": [
            {
                "provider": "generic",
                "url": "https://rmik.gyatechindonesia.com/updates/"
            }
        ],
        "directories": {
            "output": "dist"
        },
        "files": [
            "src/**",
            "electron/**",
            "config.json",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "pw-browsers",
                "to": "pw-browsers"
            }
        ],
        "win": {
            "target": "nsis",
            "icon": "electron/ui/assets/icon-rmik.png",
            "requestedExecutionLevel": "asInvoker"
        },
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "allowElevation": false,
            "allowToChangeInstallationDirectory": false,
            "installerLanguages": [
                "id"
            ],
            "include": "electron/installer.nsh"
        }
    }
}
