<!-- TOP BAR -->
<div class="drag-region bg-white dark:bg-slate-900 px-4 sm:px-6 py-3 rounded-2xl sm:rounded-2xl flex items-center justify-between gap-4 shadow-sm border border-slate-200 dark:border-slate-800 mb-4 shrink-0">

    <div class="flex items-center gap-3 overflow-hidden">
        <div class="no-drag w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
        </div>
        <div class="min-w-0 flex flex-col justify-center">
            <div class="flex items-center gap-2">
                <h2 class="font-bold leading-none text-slate-900 dark:text-white truncate" id="displayUser">Admin</h2>
                <span id="appVersionLabel" class="text-[9px] font-mono font-bold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 px-1.5 py-0.5 rounded">v0.0.0</span>
            </div>
            <span class="text-[10px] text-slate-400 dark:text-slate-500 font-mono tracking-tighter truncate block mt-0.5" id="displayKey">GYA-XXXX-XXXX</span>
        </div>
    </div>

    <div class="no-drag flex items-center gap-2 sm:gap-3 shrink-0">
        <div id="windowSize" class="text-[10px] font-mono font-bold text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded border border-slate-200 dark:border-slate-700 hidden sm:block">0×0</div>

        <div class="w-px h-5 bg-slate-200 dark:bg-slate-700"></div>

        <button id="btnHelp" class="p-2 bg-slate-100 dark:bg-slate-800 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors" title="Panduan Penggunaan">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.44 0 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
        </button>

        <button id="btnSettings" class="p-2 bg-slate-100 dark:bg-slate-800 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors" title="Pengaturan Lanjutan">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </button>

        <!-- Tombol Notifikasi Update OTA -->
        <button id="btnUpdateNotify" class="relative p-2 bg-amber-50 dark:bg-amber-900/30 rounded-xl hover:bg-amber-100 dark:hover:bg-amber-900/50 transition-colors" title="Pembaruan Aplikasi Tersedia">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            <span id="badgeUpdateNotif" class="absolute -top-1.5 -right-1.5 h-4 w-4 rounded-full bg-red-500 border-2 border-white dark:border-slate-900 text-white flex items-center justify-center text-[9px] font-bold shadow-sm transition-all duration-300 opacity-0 scale-50">1</span>
        </button>

        <button id="btnThemeToggle" class="p-2 bg-slate-100 dark:bg-slate-800 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
            <svg id="themeIcon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
        </button>

        <div id="clock" class="text-sm sm:text-lg font-mono font-bold text-emerald-600 dark:text-emerald-400">00:00:00</div>

        <div class="w-px h-5 bg-slate-200 dark:bg-slate-700"></div>

        <button id="btnLogout" class="flex items-center gap-1.5 py-2 px-3 bg-red-50 dark:bg-red-500/10 text-red-600 hover:bg-red-100 dark:hover:bg-red-500/20 rounded-xl transition-all font-bold text-[10px] sm:text-xs">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <span class="hidden sm:inline">Logout</span>
        </button>

        <div class="w-px h-5 bg-slate-200 dark:bg-slate-700"></div>

        <button id="btnMinimize" class="w-8 h-8 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-500 hover:text-slate-700 dark:hover:text-slate-200 transition-all" title="Minimize">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
                <line x1="4" y1="12" x2="20" y2="12"/>
            </svg>
        </button>
        <button id="btnMaximize" class="w-8 h-8 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-500 hover:text-slate-700 dark:hover:text-slate-200 transition-all" title="Maximize">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            </svg>
        </button>
        <button id="btnClose" class="w-8 h-8 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-red-100 dark:hover:bg-red-500/20 text-slate-500 hover:text-red-500 transition-all" title="Close">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
</div>

<!-- MAIN GRID -->
<div class="flex-1 grid grid-cols-1 lg:grid-cols-12 gap-4 min-h-0 overflow-hidden">

    <!-- LEFT COLUMN -->
    <div class="lg:col-span-4 flex flex-col gap-4 overflow-y-auto no-scrollbar min-h-0 pb-4">

        <!-- Node Control Card -->
        <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 shrink-0">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-lg text-slate-900 dark:text-white tracking-tight">Node Control</h3>
                <div id="statusIndicator" class="flex items-center gap-2 shrink-0">
                    <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Offline</span>
                    <div class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-slate-700 transition-all"></div>
                </div>
            </div>

            <!-- Session Banner -->
            <div id="sessionBanner" class="mb-4 rounded-2xl px-4 py-3 flex items-center justify-between gap-3 bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/30">
                <div class="flex items-center gap-2.5">
                    <div id="sessionDot" class="w-2.5 h-2.5 rounded-full bg-amber-400 shrink-0"></div>
                    <span id="sessionLabel" class="text-[11px] font-bold text-amber-700 dark:text-amber-400">Memeriksa sesi...</span>
                </div>
                <div class="flex gap-2 shrink-0">
                    <button id="btnLogoutSI" class="hidden text-[10px] font-bold py-1.5 px-3 bg-red-100 hover:bg-red-200 text-red-600 rounded-xl transition-colors">
                        Keluar
                    </button>
                    <button id="btnLoginSI" class="hidden text-[10px] font-bold py-1.5 px-3 bg-amber-500 hover:bg-amber-600 text-white rounded-xl transition-colors">
                        Login
                    </button>
                </div>
            </div>

            <!-- Start / Stop -->
            <div class="grid grid-cols-1 gap-3">
                <button id="btnStart" class="group flex items-center justify-center gap-3 bg-emerald-600 hover:bg-emerald-700 text-white py-4 rounded-2xl font-bold transition-all transform active:scale-95 shadow-lg shadow-emerald-200 dark:shadow-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    START APP
                </button>
                <button id="btnStop" disabled class="flex items-center justify-center gap-3 bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-600 py-4 rounded-2xl font-bold cursor-not-allowed transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10h6v4H9z" />
                    </svg>
                    STOP APP
                </button>
            </div>

            <!-- Info Panel -->
            <div class="mt-5 pt-5 border-t border-slate-100 dark:border-slate-800 space-y-2.5">
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Nama Perangkat</span>
                    <span id="infoPcLabel" class="text-emerald-600 dark:text-emerald-400 font-mono">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Tugas</span>
                    <span id="infoTaskType" class="text-emerald-600 dark:text-emerald-400">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Kategori</span>
                    <span id="infoMode" class="text-emerald-600 dark:text-emerald-400">—</span>
                </div>

                <div class="w-full h-px bg-slate-100 dark:bg-slate-800"></div>

                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Total Antrean</span>
                    <span id="infoPending" class="text-amber-500 font-mono">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Running (x/total)</span>
                    <span id="infoRunning" class="text-emerald-500 font-mono">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Status Kerja</span>
                    <span id="infoBusy" class="text-slate-400 font-mono">—</span>
                </div>
            </div>
        </div>

        <!-- System Account Card -->
        <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 shrink-0 relative overflow-hidden">
            <div class="absolute -right-4 -top-4 text-slate-50 dark:text-slate-800/50 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            
            <div class="relative z-10">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="font-bold text-lg text-slate-900 dark:text-white tracking-tight">Akun Sehat</h3>
                    <span id="accountStatusLabel" class="text-[10px] font-bold text-slate-400 tracking-wider">KOSONG</span>
                </div>
                <p class="text-xs text-slate-500 mb-5">Detail kredensial untuk sinkronisasi web</p>

                <div class="space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Email / NIK</label>
                        <input type="text" id="accEmail" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 transition-all font-mono text-sm shadow-inner" placeholder="Puskesmas email">
                    </div>
                    
                    <div class="relative">
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Password</label>
                        <input type="password" id="accPass" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 transition-all font-mono text-sm shadow-inner" placeholder="••••••••">
                        <button id="btnTogglePass" class="absolute right-4 bottom-3 text-slate-400 hover:text-emerald-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>

                    <div class="flex gap-2 pt-2">
                        <button id="btnLoadAccount" class="flex-1 py-3 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-xl font-bold text-xs transition-colors hidden">
                            MUAT AKUN
                        </button>
                        <button id="btnSaveSettings" class="flex-1 py-3 bg-slate-800 dark:bg-emerald-600 hover:bg-slate-900 dark:hover:bg-emerald-500 text-white rounded-xl font-bold text-xs transition-colors shadow-sm">
                            UPDATE AKUN
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
