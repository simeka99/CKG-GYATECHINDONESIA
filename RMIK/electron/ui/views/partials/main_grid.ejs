<div class="flex-1 grid grid-cols-1 lg:grid-cols-12 gap-4 min-h-0 overflow-hidden">

    <!-- KIRI: Node Control + Akun -->
    <div class="lg:col-span-4 flex flex-col gap-4 overflow-y-auto no-scrollbar min-h-0 pb-4">

        <!-- Node Control Card -->
        <div
            class="bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 shrink-0">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-lg text-slate-900 dark:text-white tracking-tight">Node Control</h3>
                <div id="statusIndicator" class="flex items-center gap-2 shrink-0">
                    <span
                        class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Offline</span>
                    <div class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-slate-700 transition-all"></div>
                </div>
            </div>

            <!-- Session Banner -->
            <div id="sessionBanner"
                class="mb-4 rounded-2xl px-4 py-3 flex items-center justify-between gap-3 bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/30">
                <div class="flex items-center gap-2.5">
                    <div id="sessionDot" class="w-2.5 h-2.5 rounded-full bg-amber-400 shrink-0"></div>
                    <span id="sessionLabel" class="text-[11px] font-bold text-amber-700 dark:text-amber-400">Memeriksa
                        sesi...</span>
                </div>
                <div class="flex gap-2 shrink-0">
                    <button id="btnLogoutSI"
                        class="hidden text-[10px] font-bold py-1.5 px-3 bg-red-100 hover:bg-red-200 text-red-600 rounded-xl transition-colors">Keluar</button>
                    <button id="btnLoginSI"
                        class="hidden text-[10px] font-bold py-1.5 px-3 bg-amber-500 hover:bg-amber-600 text-white rounded-xl transition-colors">Login</button>
                </div>
            </div>

            <!-- Start / Stop -->
            <div class="grid grid-cols-1 gap-3">
                <button id="btnStart"
                    class="group flex items-center justify-center gap-3 bg-emerald-600 hover:bg-emerald-700 text-white py-4 rounded-2xl font-bold transition-all transform active:scale-95 shadow-lg shadow-emerald-200 dark:shadow-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    START APP
                </button>
                <button id="btnStop" disabled
                    class="flex items-center justify-center gap-3 bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-600 py-4 rounded-2xl font-bold cursor-not-allowed transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10h6v4H9z" />
                    </svg>
                    STOP APP
                </button>
            </div>

            <!-- Info Panel -->
            <div class="mt-5 pt-5 border-t border-slate-100 dark:border-slate-800 space-y-2.5">
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Nama Perangkat</span>
                    <span id="infoPcLabel" class="text-emerald-600 dark:text-emerald-400 font-mono">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Tugas</span>
                    <span id="infoTaskType" class="text-emerald-600 dark:text-emerald-400">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Kategori</span>
                    <span id="infoMode" class="text-emerald-600 dark:text-emerald-400">—</span>
                </div>
                <div class="w-full h-px bg-slate-100 dark:bg-slate-800"></div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Total Antrean</span>
                    <span id="infoPending" class="text-amber-500 font-mono">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Running (x/total)</span>
                    <span id="infoRunning" class="text-emerald-500 font-mono">—</span>
                </div>
                <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-slate-400 uppercase tracking-wider">Status Kerja</span>
                    <span id="infoBusy" class="text-slate-400 font-mono">—</span>
                </div>
            </div>
        </div>

        <!-- Akun Sehat Card -->
        <div
            class="bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 shrink-0 relative overflow-hidden">
            <div class="absolute -right-4 -top-4 text-slate-50 dark:text-slate-800/50 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            <div class="relative z-10">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="font-bold text-lg text-slate-900 dark:text-white tracking-tight">Login Akun</h3>
                    <span id="accountStatusLabel"
                        class="text-[10px] font-bold text-slate-400 tracking-wider">KOSONG</span>
                </div>
                <!-- <p class="text-xs text-slate-500 mb-5">Detail kredensial untuk Web Sehat IndonesiaKu</p> -->
                <div class="space-y-4">
                    <div>
                        <label
                            class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Email/Username</label>
                        <input type="text" id="accEmail"
                            class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 transition-all font-mono text-sm shadow-inner"
                            placeholder="Masukkan email/username">
                    </div>
                    <div class="relative">
                        <label
                            class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Password</label>
                        <input type="password" id="accPass"
                            class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 transition-all font-mono text-sm shadow-inner"
                            placeholder="Masukkan password">
                        <button id="btnTogglePass"
                            class="absolute right-4 bottom-3 text-slate-400 hover:text-emerald-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                    <div class="flex gap-2 pt-2">
                        <button id="btnLoadAccount"
                            class="flex-1 py-3 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-xl font-bold text-xs transition-colors hidden">MUAT
                            AKUN</button>
                        <button id="btnSaveSettings"
                            class="flex-1 py-3 bg-slate-800 dark:bg-emerald-600 hover:bg-slate-900 dark:hover:bg-emerald-500 text-white rounded-xl font-bold text-xs transition-colors shadow-sm">UPDATE
                            AKUN</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- KANAN: Terminal Console -->
    <div class="lg:col-span-8 flex flex-col min-h-0 mb-4 lg:mb-0">
        <div class="bg-slate-900 rounded-2xl flex-1 flex flex-col overflow-hidden shadow-2xl border border-slate-800">
            <div class="bg-black/40 px-5 py-3 border-b border-slate-800/50 flex justify-between items-center shrink-0">
                <div class="flex items-center gap-3">
                    <div class="flex gap-1.5">
                        <div class="w-2.5 h-2.5 rounded-full bg-red-500/80"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-amber-500/80"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-emerald-500/80"></div>
                    </div>
                    <span class="text-[10px] font-bold text-slate-500 tracking-widest uppercase">Node Console
                        Output</span>
                </div>
                <div class="flex items-center gap-2">
                    <span id="logCountLabel" class="text-[9px] text-slate-600 font-mono">0 lines</span>
                    <button id="btnVerbose"
                        class="flex items-center gap-1.5 py-1 px-3 bg-amber-500/20 text-amber-400 rounded-lg transition-all text-[9px] font-bold border border-amber-500/30">LOG
                        ON</button>
                    <button id="btnClear"
                        class="flex items-center gap-1.5 py-1 px-3 bg-slate-800 hover:bg-red-500/20 text-slate-400 hover:text-red-400 rounded-lg transition-all text-[9px] font-bold border border-slate-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 001 1v3M4 7h16" />
                        </svg>
                        CLEAR
                    </button>
                </div>
            </div>
            <div id="logArea"
                class="flex-1 p-5 text-[11px] sm:text-xs overflow-y-auto custom-scroll space-y-1 leading-relaxed font-mono text-slate-300 bg-black/10">
                <p class="text-emerald-500/60">>> System ready. Waiting for node initiation.</p>
            </div>
            <div
                class="px-6 py-2.5 bg-black/40 border-t border-slate-800/30 text-[9px] text-slate-500 flex items-center shrink-0 font-mono">
                <div class="flex-1 flex items-center">
                    <span class="flex items-center gap-2 text-slate-400">
                        <span class="w-1.5 h-1.5 bg-slate-700 rounded-full inline-block" id="footerDot"></span>
                        NODE ENGINE
                    </span>
                </div>
                <div class="flex-[2] flex justify-center overflow-hidden">
                    <span id="displayDevice" class="text-amber-400 uppercase tracking-tighter truncate px-4">—</span>
                </div>
                <div class="flex-1 flex justify-end">
                    <span id="logStatus" class="tracking-widest uppercase text-emerald-500 font-bold">IDLE</span>
                </div>
            </div>
        </div>
    </div>
</div>

<footer
    class="text-center py-2.5 text-slate-400 dark:text-slate-600 text-[10px] font-bold uppercase tracking-[0.2em] shrink-0">
    RMIK Medical Record © 2026 — GYATECH INDONESIA
</footer>
