{
  "manifest_version": 3,
  "name": "BPJS Auto Screening",
  "version": "1.0.11",
  "description": "Automated screening form filler for BPJS Health website with device-based access control",
  "author": "GYA Tech Indonesia",
  "homepage_url": "https://gyatechindonesia.com",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://webskrining.bpjs-kesehatan.go.id/*",
    "https://sehatindonesiaku.kemkes.go.id/*",
    "https://rmik.gyatechindonesia.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BPJS Auto Screening"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://webskrining.bpjs-kesehatan.go.id/*",
        "https://sehatindonesiaku.kemkes.go.id/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "version_name": "v1.0.11"
}
